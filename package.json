{
  "name": "toolguard",
  "version": "1.0.0",
  "description": "ToolGuard MVP - agent permissions API for tool authorization, approvals, audit, and replay.",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "worker": "node dist/src/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down --volumes --remove-orphans",
    "seed": "tsx prisma/seed.ts",
    "demo": "tsx examples/support-agent-demo.ts",
    "build:packages": "npm run build -w @toolguard/client && npm run build -w @toolguard/openai && npm run build -w @toolguard/mcp-proxy",
    "example:openai": "npm run build:packages && tsx examples/openai-agent.ts",
    "acceptance:live": "tsx scripts/live-acceptance.ts",
    "prepare": "prisma generate"
  },
  "keywords": [
    "fastify",
    "prisma",
    "redis",
    "policy-engine",
    "toolguard"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "prisma": "^6.19.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "openai": "^4.96.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@prisma/client": "^6.19.0",
    "bullmq": "^5.63.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.8.1",
    "pino-pretty": "^13.1.2",
    "zod": "^4.1.11"
  },
  "overrides": {
    "openai": {
      "zod": "$zod"
    }
  }
}
